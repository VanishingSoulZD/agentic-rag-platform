# Default provider behavior:
# - If provider is explicitly passed in code, that provider is used.
# - Otherwise, the app auto-detects providers by available keys.
# - If no provider keys are available, OpenAI is used as final fallback.

# OpenAI (default fallback provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional provider credentials for auto-detection
# FIREWORKS_API_KEY=
# FIREWORKS_BASE_URL=
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=
# GEMINI_API_KEY=
# GEMINI_BASE_URL=

# Mock mode (for local/dev tests)
MOCK_LLM=true

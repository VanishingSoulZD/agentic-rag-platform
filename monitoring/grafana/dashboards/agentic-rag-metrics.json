{
  "id": null,
  "uid": "agentic-rag-metrics",
  "title": "Agentic RAG Metrics",
  "tags": ["rag", "metrics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "TTFT P95 (ms)",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets": [{"expr": "ttft_ms", "refId": "A"}],
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Overall P95 Latency (ms)",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "targets": [{"expr": "response_time_ms{quantile=\"0.95\"}", "refId": "A"}],
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "targets": [{"expr": "cache_hit_rate", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "timeseries",
      "title": "P95 Latency: Cache Hit vs Miss",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {"expr": "response_time_ms_cache_hit_p95", "legendFormat": "cache_hit", "refId": "A"},
        {"expr": "response_time_ms_cache_miss_p95", "legendFormat": "cache_miss", "refId": "B"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Token Usage",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [
        {"expr": "prompt_tokens", "legendFormat": "prompt_tokens", "refId": "A"},
        {"expr": "completion_tokens", "legendFormat": "completion_tokens", "refId": "B"}
      ]
    }
  ],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {}
}
